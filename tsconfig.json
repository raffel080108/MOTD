{
  "compilerOptions": {
    "target": "esnext",
    "moduleResolution": "bundler",
    "module": "esnext",
    "strict": true,
    "noImplicitAny": true,
    "strictNullChecks": true,
    "rootDir": "./src",
    "outDir": "./dist",
    "paths": {
      "*": ["./src/types/*"]
    }
  },
  "include": [
    "./src/**/*.ts",
    "./src/types/**/*.d.ts"
  ]
}
